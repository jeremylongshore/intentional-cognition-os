    "pdf-parse": "^2.4.5",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/turndown": "^5.0.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
