{
  "name": "@ico/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ico": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@ico/compiler": "workspace:*",
    "@ico/kernel": "workspace:*",
    "@ico/types": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  }
}
